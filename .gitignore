# 环境变量（包含真实 API Key，仅本地使用）
.env

# Python
__pycache__/
*.py[cod]
*.egg-info/
dist/
build/
venv/

# ======== 数据文件（不上传具体文档） ========
# PPT 课件
data/raw_docs/ppt/*
!data/raw_docs/ppt/.gitkeep

# 历史优秀学生报告
data/raw_docs/sample_reports/*
!data/raw_docs/sample_reports/.gitkeep

# 参考报告（仅保留 metadata.json 模板和 .gitkeep）
data/reference_reports/*
!data/reference_reports/metadata.json
!data/reference_reports/.gitkeep

# 向量数据库
data/vector_db/*
!data/vector_db/.gitkeep

# 学生上传文件
data/uploads/incomplete/*
!data/uploads/incomplete/.gitkeep
data/uploads/completed/*
!data/uploads/completed/.gitkeep

# ======== 输出产物 ========
outputs/flowcharts/*
!outputs/flowcharts/.gitkeep
outputs/evaluations/*
!outputs/evaluations/.gitkeep

# IDE
.vscode/
.idea/

# macOS
.DS_Store

# Streamlit
.streamlit/
